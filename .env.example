# Copy this file to .env and fill in real values. Never commit .env.

# Public HTTPS port the recbot nginx sidecar listens on (same domain as
# Collxct, different port). The domain itself is hardcoded in
# nginx/recbot.conf — edit that file if it's not collxct.com.ng.
PUBLIC_PORT=8443

# Random long string used to sign auth cookies. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Seed admin account created on first boot if no admin user exists yet.
ADMIN_EMAIL=olufemi.mohammed11@gmail.com
ADMIN_PASSWORD=change-me

# Paystack (subscription billing)
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=https://your-domain.example/paystack/webhook

# Twilio (WhatsApp messaging)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Public URL of this app, used to build clickable order links in the
# WhatsApp alerts sent to business owners. No trailing slash.
PUBLIC_BASE_URL=https://collxct.com.ng:8443

# Action-needed WhatsApp reminders: while an order is waiting on the business
# (delivery fee to set, payment to confirm), the owner is re-pinged every
# ACTION_REMINDER_AFTER_MINUTES, up to ACTION_REMINDER_MAX times per stage.
ACTION_REMINDER_AFTER_MINUTES=10
ACTION_REMINDER_MAX=3

# Local-time offset used for business opening hours (minutes from UTC).
# 60 = WAT / Lagos. Can also be set per business in the database.
DEFAULT_UTC_OFFSET_MINUTES=60

# Days a business keeps taking orders after its paid plan expires, before the
# bot pauses ordering. Owners get daily WhatsApp renewal reminders from 3 days
# before expiry until 7 days after.
PLAN_GRACE_DAYS=3

# Annual prepay: businesses paying yearly are charged this many months for 12
# months of service (10 = "2 months free").
ANNUAL_MONTHS_CHARGED=10

# Delivery-fee auto-calculation (per-business feature, configured in the
# dashboard). Distances beyond this many km fall back to a manually set fee —
# it usually means the geocoder matched the wrong place.
MAX_AUTO_DELIVERY_KM=30
# Identify ourselves to OpenStreetMap Nominatim (their usage policy requires a
# contact in the User-Agent).
GEOCODER_USER_AGENT=RecbotCRM/1.0 (recbot@collxct.com.ng)
