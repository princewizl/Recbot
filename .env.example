# Copy this file to .env and fill in real values. Never commit .env.

# Public HTTPS port the recbot nginx sidecar listens on (same domain as
# Collxct, different port). The domain itself is hardcoded in
# nginx/recbot.conf — edit that file if it's not collxct.com.ng.
PUBLIC_PORT=8443

# Random long string used to sign auth cookies. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Seed admin account created on first boot if no admin user exists yet.
ADMIN_EMAIL=olufemi.mohammed11@gmail.com
ADMIN_PASSWORD=change-me

# Paystack (subscription billing)
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=https://your-domain.example/paystack/webhook

# Twilio (WhatsApp messaging)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
